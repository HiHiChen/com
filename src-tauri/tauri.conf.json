{
  "$schema": "https://raw.githubusercontent.com/nicby/tauri/v2/crates/tauri-config-schema/schema.json",
  "productName": "计算器",
  "version": "1.0.0",
  "identifier": "com.calculator.desktop",
  "build": {
    "frontendDist": "../www",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "计算器",
        "width": 360,
        "height": 540,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
